# ── Supabase ──────────────────────────────────────────────────────────────────
# The two NEXT_PUBLIC_* values are exposed to the browser (middleware, client
# components, auth flow). The service role key is server-only.
NEXT_PUBLIC_SUPABASE_URL=https://<your-project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<your-anon-key>
SUPABASE_SERVICE_ROLE_KEY=<your-service-role-key>

# Used by the Python sync scripts under scripts/ — same URL as above, just
# without the NEXT_PUBLIC_ prefix. Python doesn't read NEXT_PUBLIC_*. The
# Python scripts pair this with SUPABASE_SERVICE_ROLE_KEY (set above).
SUPABASE_URL=https://<your-project-ref>.supabase.co

# ── Google OAuth (Calendar + Gmail + Fit) ────────────────────────────────────
# See docs/google-oauth-setup.md for setup instructions
GOOGLE_CLIENT_ID=<your-google-client-id>
GOOGLE_CLIENT_SECRET=<your-google-client-secret>
GOOGLE_REFRESH_TOKEN=<your-google-refresh-token>

# ── Fitness integrations ──────────────────────────────────────────────────────
# See docs/fitness-tracker-setup.md for setup instructions
OURA_ACCESS_TOKEN=<your-oura-personal-access-token>
FITBIT_CLIENT_ID=<your-fitbit-client-id>
FITBIT_CLIENT_SECRET=<your-fitbit-client-secret>
FITBIT_REFRESH_TOKEN=<obtained-via-python3-scripts/sync-fitbit.py---setup>
FITBIT_WEIGHT_UNIT=lbs  # lbs or kg — must match your Fitbit profile unit setting (default: lbs)
GOOGLE_FIT_REFRESH_TOKEN=<obtained-via-python3-scripts/sync-googlefit.py---setup>
# Optional: if your Google Fit project uses separate OAuth credentials from
# Calendar/Gmail, set these. If unset, GOOGLE_CLIENT_ID/SECRET above are used.
GOOGLE_FIT_CLIENT_ID=
GOOGLE_FIT_CLIENT_SECRET=

# ── Stocks (Polygon.io, optional) ────────────────────────────────────────────
# Used by the dashboard stock widget and /api/stocks/*. If unset, stocks
# features stay hidden (Settings surfaces `hasApiKey=false`).
POLYGON_API_KEY=<your-polygon-api-key>

# ── Sports (TheSportsDB, optional) ───────────────────────────────────────────
# Used by the dashboard sports widget and /api/sports/*. If unset, requests
# fall through to TheSportsDB's public test key "3" (heavily rate-limited).
SPORTSDB_API_KEY=<your-thesportsdb-api-key>
# Only `thesportsdb` is wired up currently; reserved for future providers.
SPORTS_PROVIDER=thesportsdb

# ── LLM providers ────────────────────────────────────────────────────────────
# Anthropic is required for the chat route and meal-suggestion routes.
ANTHROPIC_API_KEY=<your-anthropic-api-key>
# Groq is used for the "fast" model path in chat when selected. Optional.
GROQ_API_KEY=<your-groq-api-key>

# ── Timezone ─────────────────────────────────────────────────────────────────
# IANA timezone id. Used by date-window helpers in the chat tools and
# Python syncs. Defaults to America/Los_Angeles if unset.
USER_TIMEZONE=America/Los_Angeles

# ── Cron endpoints ───────────────────────────────────────────────────────────
# Bearer secret required by /api/cron/sync and /api/cron/reset-demo.
# Vercel's cron scheduler forwards it via Authorization: Bearer <value>.
CRON_SECRET=<random-string-used-by-vercel-cron-invocations>
# UUID of the real (non-demo) account, used only by /api/cron/sync so the
# scheduled sync writes under the owner's user_id rather than an auth'd session.
OWNER_USER_ID=<owner-supabase-auth-uuid>

# ── Notifications (ntfy.sh) ───────────────────────────────────────────────────
# See docs/notifications-setup.md — pick any unique topic string
NTFY_TOPIC=mr-bridge-yourname-1234
# Base URL of your deployed web app — tapping a notification opens this URL + the relevant path
APP_URL=https://your-app.vercel.app

# ── Demo account ──────────────────────────────────────────────────────────────
# Created in the Supabase Auth dashboard, then referenced by seed scripts and
# the nightly reset cron. Every demo-scoped insert uses this UUID — never the
# owner's UID — to avoid the #133 journal-leak class of regressions.
# Obtain with: python3 scripts/print_owner_id.py (after signing in as demo)
DEMO_USER_ID=<demo-account-supabase-auth-uuid>
DEMO_EMAIL=demo@mr-bridge.app
DEMO_PASSWORD=<demo-account-password>
NEXT_PUBLIC_DEMO_EMAIL=<same-as-DEMO_EMAIL-exposed-to-browser-for-try-demo-button>
NEXT_PUBLIC_DEMO_PASSWORD=<same-as-DEMO_PASSWORD-exposed-to-browser>

# ── Voice interface (Jarvis) — optional ──────────────────────────────────────
PICOVOICE_ACCESS_KEY=<your-picovoice-access-key>

# ── Smoke tests ──────────────────────────────────────────────────────────────
# Credentials for the dedicated smoke-test Supabase user. See
# docs/smoke-testing.md for setup. Never point smoke at your real account —
# it writes to chat_sessions / chat_messages and would pollute real data.
SMOKE_TEST_EMAIL=smoke+test@mr-bridge.test
SMOKE_TEST_PASSWORD=<stored-in-1Password>
# Service-role key used only by the smoke suite to verify rows landed in
# chat_messages (bypasses RLS). Same value as SUPABASE_SERVICE_ROLE_KEY —
# aliased here so the smoke code path is explicit. Never run smoke against
# production Supabase.
SMOKE_SUPABASE_SERVICE_KEY=<service-role-key>
