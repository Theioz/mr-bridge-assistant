# ── Supabase ──────────────────────────────────────────────────────────────────
SUPABASE_URL=https://<your-project-ref>.supabase.co
SUPABASE_ANON_KEY=<your-anon-key>
SUPABASE_SERVICE_ROLE_KEY=<your-service-role-key>

# ── Google OAuth (Calendar + Gmail + Fit) ────────────────────────────────────
# See docs/google-oauth-setup.md for setup instructions
GOOGLE_CLIENT_ID=<your-google-client-id>
GOOGLE_CLIENT_SECRET=<your-google-client-secret>
GOOGLE_REFRESH_TOKEN=<your-google-refresh-token>

# ── Fitness integrations ──────────────────────────────────────────────────────
# See docs/fitness-tracker-setup.md for setup instructions
OURA_ACCESS_TOKEN=<your-oura-personal-access-token>
FITBIT_CLIENT_ID=<your-fitbit-client-id>
FITBIT_CLIENT_SECRET=<your-fitbit-client-secret>
FITBIT_REFRESH_TOKEN=<obtained-via-python3-scripts/sync-fitbit.py---setup>

# ── Notifications (ntfy.sh) ───────────────────────────────────────────────────
# See docs/notifications-setup.md — pick any unique topic string
NTFY_TOPIC=mr-bridge-yourname-1234

# ── Voice interface (Jarvis) — optional ──────────────────────────────────────
ANTHROPIC_API_KEY=<your-anthropic-api-key>
PICOVOICE_ACCESS_KEY=<your-picovoice-access-key>
