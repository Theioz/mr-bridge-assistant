# Mr. Bridge — root .env (Python scripts + the MCP server).
# Real values live in Vaultwarden as the Secure Note `mr-bridge-env`.
#
# SELF-HOSTED since 2026-07-13 (#476). No Vercel, no Supabase Cloud, no Anthropic API.

# ── Supabase (self-hosted, on compute-core) ──────────────────────────────────
# The browser and the server reach Supabase on DIFFERENT urls. This is deliberate
# and must not be "simplified":
#   SUPABASE_URL           the tailnet vhost — what a browser/laptop uses
#   SUPABASE_INTERNAL_URL  set ONLY inside the app container. The app runs on
#                          compute-core, which has no route to Surface's tailnet IP,
#                          so the public vhost fails there with "fetch failed".
SUPABASE_URL=https://supabase.jl-infra-lab.com
SUPABASE_ANON_KEY=<anon-key>
SUPABASE_SERVICE_ROLE_KEY=<service-role-key>

# These are LEGACY JWT keys, minted by docker/supabase/gen-keys.sh in jl-homelab.
# Supabase Cloud's newer sb_publishable_/sb_secret_ keys are a Cloud-only auth
# system and do NOT work against self-hosted GoTrue/PostgREST.

# ── The one you cannot lose ──────────────────────────────────────────────────
# pgcrypto key for user_integrations.refresh_token_encrypted — the Google,
# Google Health and Oura REFRESH TOKENS. Lose it and every integration must be
# re-authorised by hand. Always prove it decrypts a real row before trusting a restore.
ENCRYPTION_KEY=<32-byte-hex-key>

# ── Identity ─────────────────────────────────────────────────────────────────
# A literal auth.users UUID. Every table FKs to it and the cron resolves the owner
# through it, so it must match the database exactly.
OWNER_USER_ID=<owner-auth-uuid>

# ── Google OAuth (Calendar + Gmail + Fit) ────────────────────────────────────
# Providers redirect the BROWSER (which is on the tailnet), so they never need to
# reach the URL themselves — which is why a tailnet-only host works for OAuth.
GOOGLE_CLIENT_ID=<google-client-id>
GOOGLE_CLIENT_SECRET=<google-client-secret>
GOOGLE_OAUTH_REDIRECT_URI=https://mr-bridge.jl-infra-lab.com/api/auth/google/callback

# ── Fitness integrations ─────────────────────────────────────────────────────
# Google Health (#607) replaced both Fitbit (Web API turned down Sept 2026) and
# Google Fit (REST API deprecated). It reuses GOOGLE_CLIENT_ID/SECRET above but is
# consented SEPARATELY, so the health refresh token carries no Gmail scope — Google
# revokes Gmail-scoped tokens on password change, which would otherwise take the
# unattended fitness sync down with it. Register this callback on the same OAuth
# client as GOOGLE_OAUTH_REDIRECT_URI.
GOOGLE_HEALTH_OAUTH_REDIRECT_URI=https://mr-bridge.jl-infra-lab.com/api/auth/google-health/callback

# ── Nutrition: USDA FoodData Central ─────────────────────────────────────────
# Macros come from MEASURED DATA, not a language model's memory. Free key:
#   https://fdc.nal.usda.gov/api-key-signup.html
FDC_API_KEY=<fdc-api-key>

# ── Local model (Ollama on compute-core) ─────────────────────────────────────
# Identifies foods and reads quantity+unit. NEVER asked for grams or calories —
# it was measured ~2x off on portion weight (a large egg at 105g; real ~50g), so
# USDA does the arithmetic.
OLLAMA_URL=http://127.0.0.1:11434
OLLAMA_MODEL=qwen2.5vl:7b

# ── Stocks / sports ──────────────────────────────────────────────────────────
# ESPN needs no key. TheSportsDB was removed in #368 — there is no SPORTSDB key.
POLYGON_API_KEY=<polygon-api-key>

# ── Media metadata (Library / Backlog) ───────────────────────────────────────
TMDB_API_KEY=<tmdb-api-key>
IGDB_CLIENT_ID=<igdb-client-id>
IGDB_CLIENT_SECRET=<igdb-client-secret>
GOOGLE_BOOKS_API_KEY=<google-books-api-key>

# ── Timezone ─────────────────────────────────────────────────────────────────
USER_TIMEZONE=America/Los_Angeles

# ── Cron ─────────────────────────────────────────────────────────────────────
# Bearer secret for /api/cron/*. Called by the NODE's crontab (compute-core) now —
# web/vercel.json is deleted.
CRON_SECRET=<random-string>

# ── Notifications (ntfy.sh) ──────────────────────────────────────────────────
# MIND THE SPELLING. Vercel production had this as NFTY_TOPIC while the code reads
# NTFY_TOPIC, so /api/notifications/push silently returned 503 for months. Do not
# reintroduce the typo.
NTFY_TOPIC=<your-ntfy-topic>

# Where a tapped notification opens. Tailnet-only — this hostname resolves to a tailnet
# IP, so it is reachable from your phone/laptop on the tailnet but NOT from compute-core
# itself (the ACL does not grant compute-core -> the node serving it).
APP_URL=https://mr-bridge.jl-infra-lab.com

# Origin for HOST-LOCAL server-to-server calls — scripts on compute-core calling the app's
# own API (scripts/weekly_plan.py context|submit). Must NOT be APP_URL: a call to the
# tailnet host from compute-core fails at connect, which reads as "the app is down".
INTERNAL_APP_URL=http://localhost:3000

# Share links go to people OUTSIDE the tailnet, so they must resolve on the PUBLIC
# host. Using APP_URL here would hand recipients an unreachable link.
SHARE_BASE_URL=https://share.jl-infra-lab.com

# ── Demo account ─────────────────────────────────────────────────────────────
DEMO_USER_ID=<demo-auth-uuid>
DEMO_EMAIL=demo@mr-bridge.app
DEMO_PASSWORD=<demo-password>
NEXT_PUBLIC_DEMO_EMAIL=<same-as-DEMO_EMAIL>
NEXT_PUBLIC_DEMO_PASSWORD=<same-as-DEMO_PASSWORD>

# ── REMOVED in #476 ──────────────────────────────────────────────────────────
# ANTHROPIC_API_KEY     the in-app chat and Claude-vision meal analysis are gone.
#                       Chat is the MCP server (web/mcp/) on the Claude
#                       subscription; macros come from USDA + the local model.
#                       One residual call site remains: api/meals/scan-chat.
# GROQ_API_KEY          was only the demo account's chat path.
# PICOVOICE_ACCESS_KEY  voice/ was deleted — it had been broken for months (its
#                       config pointed at memory/*.md and a rules file that no
#                       longer exist).
