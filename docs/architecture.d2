direction: right

# ── Nodes ─────────────────────────────────────────────────────────────────────

data_sources: "Data Sources\n\nOura Ring · Fitbit\nGoogle Fit · Renpho ⚠"

sync: "Sync Layer\n\nPython (CLI)\n  sync-oura · sync-fitbit\n  sync-googlefit · sync-renpho\n\nTypeScript\n  oura.ts · fitbit.ts\n  googlefit.ts · stocks.ts\n\nCron: api/cron/sync\n        (daily 6am PST)\nManual: api/sync/{oura·fitbit·googlefit}"

supabase: "Supabase Postgres\n18 tables · RLS enforced"

nextjs: "Next.js · Vercel\n\nAPI Routes\n  api/chat  (21 tools · streaming)\n  api/meals/analyze-photo · log\n  api/weather\n  api/stocks/refresh\n  api/google/calendar · gmail\n  api/notifications/unread-count\n\nPages\n  Dashboard · Chat · Habits · Tasks\n  Fitness · Journal · Weekly · Meals\n  Notifications · Settings"

external: "External APIs\n\nAnthropic (Claude)\nGoogle Calendar · Gmail\nOpen-Meteo\nPolygon.io\nntfy.sh  (push alerts)"

user: "Browser / Mobile"

# ── Edges ─────────────────────────────────────────────────────────────────────

# Primary left-to-right flow
data_sources -> sync
sync -> supabase: write / upsert
supabase -> nextjs: query / SSR
nextjs -> user

# Write-back
nextjs -> supabase: write

# External APIs feed into Next.js only (keeps layout linear)
external -> nextjs: OAuth · stream · vision · EOD

