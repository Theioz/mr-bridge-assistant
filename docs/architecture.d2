# To re-render:
# d2 --layout=elk --theme=200 docs/architecture.d2 docs/architecture.svg && sed -i '' 's/data-d2-version="[^"]*" preserveAspectRatio="[^"]*" viewBox="/width="100%" viewBox="/' docs/architecture.svg
# d2 --layout=elk --theme=200 --scale=2 docs/architecture.d2 docs/architecture.png

direction: right

data_sources: "Data Sources\nOura · Fitbit · Google Fit"

sync: "Sync Layer\nPython scripts · TypeScript modules\nCron (daily 6am PST) · Manual routes"

supabase: "Supabase Postgres\n18 tables · RLS enforced"

nextjs: "Next.js · Vercel\n7 API routes · 10 pages"

external: "External APIs\nAnthropic · Google Calendar · Gmail\nOpen-Meteo · Polygon.io · ntfy.sh"

user: "Browser / Mobile"

data_sources -> sync
sync -> supabase: write / upsert
supabase -> nextjs: query / SSR
nextjs -> supabase: write
nextjs -> user
external -> nextjs: OAuth · stream · vision · EOD

data_sources.style.stroke: "#10B981"
data_sources.style.font-color: "#10B981"

sync.style.stroke: "#6366F1"

supabase.style.fill: "#422006"
supabase.style.stroke: "#F59E0B"
supabase.style.font-color: "#FDE68A"
supabase.style.bold: true

nextjs.style.stroke: "#38BDF8"

external.style.stroke: "#475569"
external.style.font-color: "#94A3B8"

user.style.fill: "#F8FAFC"
user.style.stroke: "#CBD5E1"
user.style.font-color: "#1E293B"
