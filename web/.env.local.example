# ── Supabase (Next.js web app) ────────────────────────────────────────────────
# NEXT_PUBLIC_ vars are exposed to the browser (anon key only — safe)
NEXT_PUBLIC_SUPABASE_URL=https://<your-project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<your-supabase-anon-key>
# Service role key is server-side only — never expose to the browser
SUPABASE_SERVICE_ROLE_KEY=<your-supabase-service-role-key>

# ── Anthropic (Claude API) ────────────────────────────────────────────────────
ANTHROPIC_API_KEY=<your-anthropic-api-key>

# ── Google OAuth (Calendar + Gmail + Google Fit) ──────────────────────────────
# Same credentials as root .env — copy from there.
# Users connect their Google account via Settings → Integrations.
# Tokens are stored encrypted in user_integrations (Supabase) — no env token needed.
GOOGLE_CLIENT_ID=<your-google-client-id>
GOOGLE_CLIENT_SECRET=<your-google-client-secret>
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:3000/api/auth/google/callback

# ── Fitness integrations ──────────────────────────────────────────────────────
# Users connect Oura and Fitbit via Settings → Integrations.
# Per-user tokens are stored encrypted in the user_integrations Supabase table.
# See docs/fitness-tracker-setup.md for setup instructions.

# Fitbit: app-level credentials (shared across all users). Required.
FITBIT_CLIENT_ID=<your-fitbit-client-id>
FITBIT_CLIENT_SECRET=<your-fitbit-client-secret>
# Callback URL registered at dev.fitbit.com → your app → Edit → Redirect URL.
# Fitbit only allows ONE redirect URL per personal app — update it in app settings
# to switch between local and production. For local OAuth testing, temporarily set
# dev.fitbit.com to http://localhost:3000/api/auth/fitbit/callback and change back when done.
# Production: https://mr-bridge-assistant.vercel.app/api/auth/fitbit/callback
# Local:      http://localhost:3000/api/auth/fitbit/callback
FITBIT_OAUTH_REDIRECT_URI=https://mr-bridge-assistant.vercel.app/api/auth/fitbit/callback
FITBIT_WEIGHT_UNIT=lbs  # lbs or kg — must match your Fitbit profile unit setting

# ── User preferences ──────────────────────────────────────────────────────────
# IANA timezone string — used for calendar event creation and date calculations
USER_TIMEZONE=America/Los_Angeles

# ── Owner user ID ─────────────────────────────────────────────────────────────
# Your Supabase auth UID — required for cron sync to write to the correct user.
# Run: python3 scripts/print_owner_id.py to get your UID.
OWNER_USER_ID=<your-supabase-auth-uid>

# ── Vercel cron authentication ────────────────────────────────────────────────
# Required for the /api/cron/sync route; must match what you set in Vercel env vars
# Generate with: openssl rand -hex 32
CRON_SECRET=<generate-with-openssl-rand-hex-32>

# ── Stock watchlist (optional) ────────────────────────────────────────────────
# Polygon.io API key — free tier supports end-of-day data
# Required for the watchlist widget and `get_stock_quote` chat tool
# Get your key at: https://polygon.io → Dashboard → API Keys
POLYGON_API_KEY=<your-polygon-api-key>

# ── Sports widget (ESPN, no key required) ─────────────────────────────────────
# The sports widget uses ESPN's public API — no API key needed.
# TheSportsDB support has been removed (#368).

# ── Shipping / packages ───────────────────────────────────────────────────────
# AfterShip API key — required for the package delivery widget to resolve carrier
# ETAs from tracking numbers extracted from Gmail shipping confirmation emails.
# Free tier: 50 trackings/month. Get your key at: https://admin.aftership.com/api
AFTERSHIP_API_KEY=<your-aftership-api-key>

# ── Web app URL (optional) ────────────────────────────────────────────────────
# Your deployed Vercel URL — when set, push notification tap-to-open links
# will point to the relevant page in your web app
APP_URL=https://your-app.vercel.app
