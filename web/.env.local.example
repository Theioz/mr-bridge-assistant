# ── Supabase (Next.js web app) ────────────────────────────────────────────────
# NEXT_PUBLIC_ vars are exposed to the browser (anon key only — safe)
NEXT_PUBLIC_SUPABASE_URL=https://<your-project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<your-supabase-anon-key>
# Service role key is server-side only — never expose to the browser
SUPABASE_SERVICE_ROLE_KEY=<your-supabase-service-role-key>

# ── Anthropic (Claude API) ────────────────────────────────────────────────────
ANTHROPIC_API_KEY=<your-anthropic-api-key>

# ── Google OAuth (Calendar + Gmail) ──────────────────────────────────────────
# Same credentials as root .env — copy from there
GOOGLE_CLIENT_ID=<your-google-client-id>
GOOGLE_CLIENT_SECRET=<your-google-client-secret>
GOOGLE_REFRESH_TOKEN=<your-google-refresh-token>

# ── Google Fit (optional) ─────────────────────────────────────────────────────
# Separate OAuth token with fitness scopes — obtained via:
#   python3 scripts/sync-googlefit.py --setup
# Leave blank to skip Google Fit sync (sync route returns skipped:true)
GOOGLE_FIT_REFRESH_TOKEN=<obtained-via-python3-scripts/sync-googlefit.py---setup>

# ── Fitness integrations (optional) ──────────────────────────────────────────
# Leave any of these blank to skip that source in the web sync routes
# See docs/fitness-tracker-setup.md for setup instructions
OURA_ACCESS_TOKEN=<your-oura-personal-access-token>
FITBIT_CLIENT_ID=<your-fitbit-client-id>
FITBIT_CLIENT_SECRET=<your-fitbit-client-secret>
FITBIT_WEIGHT_UNIT=lbs  # lbs or kg — must match your Fitbit profile unit setting

# Note: FITBIT_REFRESH_TOKEN is NOT an env var — it's stored in the Supabase
# `profile` table (key: fitbit_refresh_token) because Fitbit rotates it on every use.
# Write it once after running `python3 scripts/sync-fitbit.py --setup`:
#   python3 -c "
#   import sys, os; sys.path.insert(0, 'scripts')
#   from dotenv import load_dotenv; load_dotenv(dotenv_path='.env')
#   from _supabase import get_client, get_owner_user_id
#   uid = get_owner_user_id()
#   get_client().table('profile').upsert({'user_id': uid, 'key': 'fitbit_refresh_token', 'value': os.environ['FITBIT_REFRESH_TOKEN']}, on_conflict='user_id,key').execute()
#   print('Done.')
#   "

# ── User preferences ──────────────────────────────────────────────────────────
# IANA timezone string — used for calendar event creation and date calculations
USER_TIMEZONE=America/Los_Angeles

# ── Owner user ID ─────────────────────────────────────────────────────────────
# Your Supabase auth UID — required for cron sync to write to the correct user.
# Run: python3 scripts/print_owner_id.py to get your UID.
OWNER_USER_ID=<your-supabase-auth-uid>

# ── Vercel cron authentication ────────────────────────────────────────────────
# Required for the /api/cron/sync route; must match what you set in Vercel env vars
# Generate with: openssl rand -hex 32
CRON_SECRET=<generate-with-openssl-rand-hex-32>

# ── Web app URL (optional) ────────────────────────────────────────────────────
# Your deployed Vercel URL — when set, push notification tap-to-open links
# will point to the relevant page in your web app
APP_URL=https://your-app.vercel.app
