# Keep the build context small and — more importantly — keep secrets out of it.
# Anything copied into a build layer is recoverable from the image.
.env
.env.*
!.env.example
**/.env
**/.env.local

.git
node_modules
web/node_modules
web/.next
web/out
voice
graphify-out
.claude
docs
runbooks
**/*.md
!web/**/*.md
web/smoke
web/playwright-report
web/test-results
